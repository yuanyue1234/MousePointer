<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MousePointer.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MousePointer.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <NavigationView
            x:Name="RootNavigation"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="RootNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="鼠标方案"
                    Icon="Edit"
                    IsSelected="True"
                    Tag="scheme" />
                <NavigationViewItem
                    Content="资源库"
                    Icon="Library"
                    Tag="resources" />
                <NavigationViewItem
                    Content="自动切换"
                    Icon="Clock"
                    Tag="switch" />
                <NavigationViewItem
                    Content="设置"
                    Icon="Setting"
                    Tag="settings" />
            </NavigationView.MenuItems>

            <Grid Padding="22,18,22,18">
                <Grid x:Name="SchemePanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="鼠标方案" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="导入、编辑、预览并应用鼠标指针方案" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                            <ComboBox
                                x:Name="SchemeCombo"
                                MinWidth="220"
                                SelectionChanged="SchemeCombo_SelectionChanged" />
                            <Button Click="NewScheme_Click" ToolTipService.ToolTip="新建">
                                <FontIcon Glyph="&#xE710;" />
                            </Button>
                            <Button Click="RenameScheme_Click" ToolTipService.ToolTip="重命名">
                                <FontIcon Glyph="&#xE70F;" />
                            </Button>
                            <Button Click="DeleteScheme_Click" ToolTipService.ToolTip="删除">
                                <FontIcon Glyph="&#xE74D;" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid
                        Grid.Row="1"
                        Margin="0,16,0,0"
                        ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="420" />
                        </Grid.ColumnDefinitions>

                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="ImportPackage_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE896;" />
                                        <TextBlock Text="导入资源包" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ImportFolder_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8B7;" />
                                        <TextBlock Text="导入文件夹" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ExportPreview_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xEB9F;" />
                                        <TextBlock Text="截图导出" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ClearAll_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE894;" />
                                        <TextBlock Text="清空" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <ListView
                                x:Name="RoleList"
                                Grid.Row="1"
                                IsItemClickEnabled="True"
                                ItemClick="RoleList_ItemClick"
                                SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid
                                            MinHeight="72"
                                            Padding="10"
                                            ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Label}" />
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Tip}" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Text="{Binding FileName}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Border
                                                Grid.Column="2"
                                                Width="30"
                                                Height="30"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="15">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="White"
                                                    Text="{Binding Badge}" />
                                            </Border>
                                            <Button
                                                Grid.Column="3"
                                                Click="PickRole_Click"
                                                Tag="{Binding RegistryName}"
                                                ToolTipService.ToolTip="选择文件">
                                                <FontIcon Glyph="&#xE8E5;" />
                                            </Button>
                                            <Button
                                                Grid.Column="4"
                                                Click="ClearRole_Click"
                                                Tag="{Binding RegistryName}"
                                                ToolTipService.ToolTip="清除">
                                                <FontIcon Glyph="&#xE711;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Border
                                Grid.Row="2"
                                Padding="12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8">
                                <StackPanel Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Text="替换鼠标指针" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="选择某一行后点击添加资源，会把文件放入当前选中的鼠标状态。" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Click="AddReplacement_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE710;" />
                                                <TextBlock Text="添加资源" />
                                            </StackPanel>
                                        </Button>
                                        <Button Click="MoveSelectedBack_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE72B;" />
                                                <TextBlock Text="移回替换区" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border
                            Grid.Column="1"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Spacing="3">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Text="实时预览" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="当前选中素材和应用状态" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="1"
                                    Spacing="8">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Click="SizeMinus_Click" Content="-" Width="38" />
                                        <ProgressBar
                                            x:Name="SizeProgress"
                                            Grid.Column="1"
                                            Maximum="15"
                                            Minimum="1" />
                                        <Button
                                            Grid.Column="2"
                                            Click="SizePlus_Click"
                                            Content="+"
                                            Width="38" />
                                    </Grid>
                                    <TextBlock x:Name="SizeText" />
                                    <ToggleSwitch
                                        x:Name="LiveSizeSwitch"
                                        Header="实时更新鼠标大小"
                                        Toggled="LiveSizeSwitch_Toggled" />
                                </StackPanel>

                                <Border
                                    Grid.Row="2"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="8">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                        <TextBlock
                                            x:Name="PreviewRoleText"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="正常选择" />
                                        <TextBlock
                                            x:Name="PreviewPathText"
                                            Width="330"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="未选择"
                                            TextAlignment="Center"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Grid
                                    Grid.Row="3"
                                    ColumnSpacing="8"
                                    RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Click="OpenPointerSettings_Click" Content="鼠标大小设置" />
                                    <Button Grid.Column="1" Click="BuildInstaller_Click" Content="生成安装包" />
                                    <Button Grid.Row="1" Click="RestoreBackup_Click" Content="恢复上一份" />
                                    <Button
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Click="ApplyScheme_Click"
                                        Content="应用"
                                        Style="{ThemeResource AccentButtonStyle}" />
                                </Grid>

                                <StackPanel
                                    Grid.Row="4"
                                    Spacing="4">
                                    <TextBlock
                                        x:Name="StatusText"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="CurrentSchemeText"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="NextSwitchText"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="ResourcePanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="3">
                        <TextBlock
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="资源库" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="管理已导入的鼠标方案，或打开在线资源库下载新资源。" />
                    </StackPanel>
                    <StackPanel
                        Grid.Row="1"
                        Margin="0,16,0,12"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button Click="OpenResourceWeb_Click" Content="在线资源库" />
                        <Button Click="ImportPackage_Click" Content="导入资源" />
                        <Button Click="ImportFolder_Click" Content="导入文件夹" />
                        <Button Click="RefreshResources_Click" Content="刷新" Style="{ThemeResource AccentButtonStyle}" />
                        <Button Click="RestoreBackup_Click" Content="恢复上一份鼠标方案" />
                    </StackPanel>
                    <ListView x:Name="ResourceList" Grid.Row="2">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Summary}" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        Click="ApplyResource_Click"
                                        Content="应用"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Tag="{Binding Name}" />
                                    <Button
                                        Grid.Column="2"
                                        Click="EditResource_Click"
                                        Content="编辑"
                                        Tag="{Binding Name}" />
                                    <Button
                                        Grid.Column="3"
                                        Click="DeleteResource_Click"
                                        Content="删除"
                                        Tag="{Binding Name}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Grid x:Name="SwitchPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="3">
                        <TextBlock
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="自动切换" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="保存时间、星期和计时切换规则，后台进程会按规则应用方案。" />
                    </StackPanel>
                    <Border
                        Grid.Row="1"
                        Margin="0,16,0,12"
                        Padding="14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock FontWeight="SemiBold" Text="计时切换" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock VerticalAlignment="Center" Text="每" />
                                <NumberBox
                                    x:Name="TimerIntervalBox"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Compact"
                                    Value="30"
                                    Width="110" />
                                <ComboBox x:Name="TimerUnitBox" Width="90">
                                    <ComboBoxItem Content="秒" IsSelected="True" />
                                    <ComboBoxItem Content="分钟" />
                                </ComboBox>
                                <ComboBox x:Name="TimerOrderBox" Width="110">
                                    <ComboBoxItem Content="顺序" IsSelected="True" />
                                    <ComboBoxItem Content="随机" />
                                </ComboBox>
                                <Button Click="SaveTimerSwitch_Click" Content="保存计时切换" Style="{ThemeResource AccentButtonStyle}" />
                            </StackPanel>
                            <ListView
                                x:Name="TimerSchemeList"
                                MaxHeight="220"
                                SelectionMode="Multiple" />
                        </StackPanel>
                    </Border>
                    <Border
                        Grid.Row="2"
                        Padding="14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock FontWeight="SemiBold" Text="固定时间切换" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox
                                    x:Name="FixedTimeBox"
                                    Header="时间"
                                    PlaceholderText="HH:mm"
                                    Width="130" />
                                <ComboBox
                                    x:Name="FixedSchemeBox"
                                    Header="方案"
                                    MinWidth="220" />
                                <Button
                                    VerticalAlignment="Bottom"
                                    Click="AddFixedTime_Click"
                                    Content="添加" />
                            </StackPanel>
                            <ListView x:Name="ScheduleList" MaxHeight="140" />
                        </StackPanel>
                    </Border>
                    <Border
                        Grid.Row="3"
                        Margin="0,12,0,0"
                        Padding="14"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock FontWeight="SemiBold" Text="星期切换" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ComboBox x:Name="Week0" Header="周一" />
                                <ComboBox x:Name="Week1" Grid.Column="1" Header="周二" />
                                <ComboBox x:Name="Week2" Grid.Column="2" Header="周三" />
                                <ComboBox x:Name="Week3" Grid.Column="3" Header="周四" />
                                <ComboBox x:Name="Week4" Grid.Row="1" Header="周五" />
                                <ComboBox x:Name="Week5" Grid.Row="1" Grid.Column="1" Header="周六" />
                                <ComboBox x:Name="Week6" Grid.Row="1" Grid.Column="2" Header="周日" />
                                <Button
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    VerticalAlignment="Bottom"
                                    Click="SaveWeekSwitch_Click"
                                    Content="保存星期切换"
                                    Style="{ThemeResource AccentButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="SettingsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="3">
                        <TextBlock
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="设置" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="存储位置、自启动、文件关联、更新与诊断" />
                    </StackPanel>
                    <StackPanel
                        Grid.Row="1"
                        Margin="0,16,0,0"
                        Spacing="10">
                        <TextBox x:Name="StoragePathBox" Header="鼠标文件存放位置" />
                        <TextBox x:Name="OutputPathBox" Header="安装包输出位置" />
                        <TextBox x:Name="GithubUrlBox" Header="GitHub 源地址" />
                        <ToggleSwitch x:Name="AutoStartSwitch" Header="自启动后台" />
                        <ToggleSwitch x:Name="HideTaskbarSwitch" Header="隐藏任务栏图标" />
                        <ToggleSwitch x:Name="FileAssociationSwitch" Header="关联 .cur / .ani 打开方式" />
                    </StackPanel>
                    <StackPanel
                        Grid.Row="2"
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button Click="SaveSettings_Click" Content="保存设置" Style="{ThemeResource AccentButtonStyle}" />
                        <Button Click="OpenStorageFolder_Click" Content="打开存储文件夹" />
                        <Button Click="CreateDesktopShortcut_Click" Content="添加桌面快捷方式" />
                        <Button Click="CheckUpdates_Click" Content="检测更新" />
                        <Button Click="CopyDiagnostics_Click" Content="复制诊断信息" />
                    </StackPanel>
                    <TextBox
                        x:Name="DiagnosticsBox"
                        Grid.Row="3"
                        Margin="0,12,0,0"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Page>

